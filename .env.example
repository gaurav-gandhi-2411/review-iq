# === LLM Providers ===
# Primary: Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Fallback: Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AI...

# === Auth ===
# API key for write endpoints (POST /extract, /extract/batch)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here

# === Hugging Face ===
# Write-scope token — https://huggingface.co/settings/tokens
# Only needed for deployment
HF_TOKEN=hf_...

# === App Config ===
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/review_iq.db
MAX_REVIEW_LENGTH=5000
RATE_LIMIT_PER_MINUTE=30
ENVIRONMENT=development
